# Knowledge Manage Docker environment template
# Copy this file to .env and fill secrets locally.
# Never commit the real .env file or the real DashScope API key.

# Internal service authentication
INTERNAL_TOKEN=

# F5 ChromaDB
CHROMA_HOST=
CHROMA_PORT=
CHROMA_COLLECTION=

# F5 Alibaba DashScope
DASHSCOPE_API_KEY=

# F5 Embedding
EMBEDDING_API_BASE=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=

# F5 Rerank
RERANK_API_BASE=
RERANK_MODEL=

# Report generation LLM, optional. Leave disabled for local demo without a provider key.
REPORT_LLM_ENABLED=false
REPORT_LLM_BASE_URL=
REPORT_LLM_MODEL=
REPORT_LLM_API_KEY=
REPORT_MATERIALS_BUCKET=report-materials
REPORT_EXPORTS_BUCKET=report-exports
