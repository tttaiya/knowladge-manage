<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.km.admin.stats.mapper.ProcessTaskStatsMapper">

    <resultMap id="ProcessTaskStatsResultMap" type="com.km.admin.stats.entity.ProcessTaskStats">
        <result property="queuedCount" column="queuedCount" jdbcType="BIGINT"/>
        <result property="runningCount" column="runningCount" jdbcType="BIGINT"/>
        <result property="successCount" column="successCount" jdbcType="BIGINT"/>
        <result property="failedCount" column="failedCount" jdbcType="BIGINT"/>
        <result property="successRate" column="successRate" jdbcType="DOUBLE"/>
        <result property="taskDate" column="taskDate" jdbcType="DATE"/>
        <result property="dailyTaskCount" column="dailyTaskCount" jdbcType="BIGINT"/>
        <result property="taskType" column="taskType" jdbcType="VARCHAR"/>
        <result property="taskStatus" column="taskStatus" jdbcType="VARCHAR"/>
        <result property="statusCount" column="statusCount" jdbcType="BIGINT"/>
    </resultMap>

    <select id="getQueuedTaskCount" resultType="java.lang.Long">
        SELECT 
            COUNT(*) as queuedCount
        FROM km_document_process_task
        WHERE task_status = 'QUEUED'
    </select>

    <select id="getRunningTaskCount" resultType="java.lang.Long">
        SELECT 
            COUNT(*) as runningCount
        FROM km_document_process_task
        WHERE task_status = 'RUNNING'
    </select>

    <select id="getSuccessTaskCount" resultType="java.lang.Long">
        SELECT 
            COUNT(*) as successCount
        FROM km_document_process_task
        WHERE task_status = 'SUCCESS'
    </select>

    <select id="getFailedTaskCount" resultType="java.lang.Long">
        SELECT 
            COUNT(*) as failedCount
        FROM km_document_process_task
        WHERE task_status = 'FAILED'
    </select>

    <select id="getTaskTrend" resultMap="ProcessTaskStatsResultMap">
        SELECT 
            DATE(created_at) as taskDate,
            COUNT(*) as dailyTaskCount
        FROM km_document_process_task
        WHERE created_at >= DATE_SUB(NOW(), INTERVAL #{days} DAY)
        GROUP BY DATE(created_at)
        ORDER BY taskDate
    </select>

    <select id="getTaskStatusDistribution" resultMap="ProcessTaskStatsResultMap">
        SELECT 
            task_status as taskStatus,
            COUNT(*) as statusCount
        FROM km_document_process_task
        GROUP BY task_status
    </select>

</mapper>