<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.km.admin.stats.mapper.DocumentChunkStatsMapper">

    <resultMap id="DocumentChunkStatsResultMap" type="com.km.admin.stats.entity.DocumentChunkStats">
        <result property="totalChunks" column="totalChunks" jdbcType="BIGINT"/>
        <result property="pendingVectorCount" column="pendingVectorCount" jdbcType="BIGINT"/>
        <result property="readyVectorCount" column="readyVectorCount" jdbcType="BIGINT"/>
    </resultMap>

    <select id="getChunkStats" resultMap="DocumentChunkStatsResultMap">
        SELECT 
            COUNT(*) as totalChunks,
            SUM(CASE WHEN vector_status = 'PENDING' THEN 1 ELSE 0 END) as pendingVectorCount,
            SUM(CASE WHEN vector_status = 'READY' THEN 1 ELSE 0 END) as readyVectorCount
        FROM km_document_chunk
        WHERE is_active = 1
    </select>

</mapper>