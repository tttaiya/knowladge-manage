<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.km.admin.stats.mapper.ReviewRecordStatsMapper">

    <resultMap id="ReviewRecordStatsResultMap" type="com.km.admin.stats.entity.ReviewRecordStats">
        <result property="approvedCount" column="approvedCount" jdbcType="BIGINT"/>
        <result property="rejectedCount" column="rejectedCount" jdbcType="BIGINT"/>
        <result property="reviewDate" column="reviewDate" jdbcType="DATE"/>
        <result property="dailyApprovedCount" column="dailyApprovedCount" jdbcType="BIGINT"/>
        <result property="dailyRejectedCount" column="dailyRejectedCount" jdbcType="BIGINT"/>
    </resultMap>

    <select id="getApprovedCount" resultType="java.lang.Long">
        SELECT 
            COUNT(*) as approvedCount
        FROM km_review_record
        WHERE action = 'APPROVE'
    </select>

    <select id="getRejectedCount" resultType="java.lang.Long">
        SELECT 
            COUNT(*) as rejectedCount
        FROM km_review_record
        WHERE action = 'REJECT'
    </select>

    <select id="getReviewTrend" resultMap="ReviewRecordStatsResultMap">
        SELECT 
            DATE(created_at) as reviewDate,
            SUM(CASE WHEN action = 'APPROVE' THEN 1 ELSE 0 END) as dailyApprovedCount,
            SUM(CASE WHEN action = 'REJECT' THEN 1 ELSE 0 END) as dailyRejectedCount
        FROM km_review_record
        WHERE created_at >= DATE_SUB(NOW(), INTERVAL #{days} DAY)
        GROUP BY DATE(created_at)
        ORDER BY reviewDate
    </select>

</mapper>