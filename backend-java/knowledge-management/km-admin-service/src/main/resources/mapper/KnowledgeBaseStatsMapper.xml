<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.km.admin.stats.mapper.KnowledgeBaseStatsMapper">

    <resultMap id="KnowledgeBaseStatsResultMap" type="com.km.admin.stats.entity.KnowledgeBaseStats">
        <result property="totalCount" column="totalCount" jdbcType="BIGINT"/>
        <result property="activeCount" column="activeCount" jdbcType="BIGINT"/>
        <result property="createTime" column="createTime" jdbcType="TIMESTAMP"/>
        <result property="category" column="category" jdbcType="VARCHAR"/>
        <result property="categoryCount" column="categoryCount" jdbcType="BIGINT"/>
    </resultMap>

    <select id="getKnowledgeBaseStats" resultMap="KnowledgeBaseStatsResultMap">
        SELECT
            COUNT(*) as totalCount,
            SUM(CASE WHEN is_deleted = 0 THEN 1 ELSE 0 END) as activeCount
        FROM km_knowledge_base
    </select>

    <!-- 由于实际表没有category字段，使用retrieval_strategy作为分类 -->
    <select id="getKnowledgeBaseDistribution" resultMap="KnowledgeBaseStatsResultMap">
        SELECT
            retrieval_strategy as category,
            COUNT(*) as categoryCount
        FROM km_knowledge_base
        WHERE is_deleted = 0
        GROUP BY retrieval_strategy
    </select>

</mapper>